@{
    ViewData["Title"] = "Geometria";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-dark text-white p-4">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-primary p-3 me-3">
                            <i id="iconaFigura" class="bi bi-square-fill fs-4 text-white"></i>
                        </div>
                        <div>
                            <h2 class="mb-0 fw-bold">Geometria</h2>
                            <small class="opacity-75">Calcola area e perimetro</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Cosa vuoi calcolare?</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-layers"></i></span>
                                <select id="tipoFigura" class="form-select border-start-0" onchange="aggiornaUI()">
                                    <option value="quadrato">Quadrato</option>
                                    <option value="rettangolo">Rettangolo</option>
                                    <option value="cerchio">Cerchio</option>
                                    <option value="pentagono">Pentagono</option>
                                </select>
                            </div>
                        </div>

                        <div class="col-md-7">
                            <div class="row g-2">
                                <div class="col">
                                    <label id="lblDato1" class="form-label fw-bold text-primary">Lato (cm)</label>
                                    <input type="number" id="dato1" class="form-control" placeholder="0.00" step="0.01">
                                </div>
                                <div id="divDato2" class="col d-none">
                                    <label class="form-label fw-bold text-primary">Altezza (cm)</label>
                                    <input type="number" id="dato2" class="form-control" placeholder="0.00" step="0.01">
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-4">
                            <button class="btn btn-primary btn-lg w-100 shadow-sm" onclick="eseguiCalcolo()">
                                <i class="bi bi-cpu-fill me-2"></i>Elabora Dati
                            </button>
                        </div>
                    </div>
                </div>

                <div id="containerRisultato" class="card-footer bg-light p-4 d-none">
                    <h5 class="text-secondary mb-3">Risultati per: <span id="resNome" class="text-dark fw-bold"></span></h5>
                    <div class="row text-center">
                        <div class="col-sm-6 mb-2">
                            <div class="p-3 bg-white border rounded shadow-sm">
                                <small class="text-uppercase text-muted d-block">Area</small>
                                <span id="resArea" class="fs-4 fw-bold text-success"></span> <small>cm²</small>
                            </div>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <div class="p-3 bg-white border rounded shadow-sm">
                                <small class="text-uppercase text-muted d-block">Perimetro</small>
                                <span id="resPerimetro" class="fs-4 fw-bold text-info"></span> <small>cm</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Mappa delle icone e delle etichette per rendere la UI dinamica
    const configFigure = {
        quadrato:   { icon: 'bi-square-fill',   label1: 'Lato' },
        rettangolo: { icon: 'bi-view-stacked',  label1: 'Base', showD2: true },
        cerchio:    { icon: 'bi-circle-fill',   label1: 'Raggio' },
        pentagono:  { icon: 'bi-pentagon-fill', label1: 'Lato' }
    };

    function aggiornaUI() {
        const tipo = document.getElementById("tipoFigura").value;
        const config = configFigure[tipo];

        // Aggiorna Icona
        document.getElementById("iconaFigura").className = `bi ${config.icon} fs-4 text-white`;

        // Aggiorna Etichetta 1
        document.getElementById("lblDato1").innerText = `${config.label1} (cm)`;

        // Gestione secondo input (per rettangolo)
        const divDato2 = document.getElementById("divDato2");
        if (config.showD2) {
            divDato2.classList.remove("d-none");
        } else {
            divDato2.classList.add("d-none");
            document.getElementById("dato2").value = ""; // Pulisce se non serve
        }

        // Nascondi risultati precedenti al cambio figura
        document.getElementById("containerRisultato").classList.add("d-none");
    }

    async function eseguiCalcolo() {
        const btn = event.currentTarget;
        const tipo = document.getElementById("tipoFigura").value;
        const d1 = document.getElementById("dato1").value;
        const d2 = document.getElementById("dato2").value;

        if (!d1 || (configFigure[tipo].showD2 && !d2)) {
            alert("Per favore, inserisci tutti i valori necessari.");
            return;
        }

        // Feedback visivo caricamento
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Elaborazione...';

        try {
            const response = await fetch('/Home/Calcola', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `tipo=${tipo}&dato1=${d1}&dato2=${d2}`
            });

            const data = await response.json();

            // Mostra Risultati
            document.getElementById("resNome").innerText = data.nome;
            document.getElementById("resArea").innerText = data.area;
            document.getElementById("resPerimetro").innerText = data.perimetro;
            document.getElementById("containerRisultato").classList.remove("d-none");

        } catch (error) {
            console.error("Errore nel calcolo:", error);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-cpu-fill me-2"></i>Elabora Dati';
        }
    }
</script>

<style>
    body {
        background-color: #f8f9fa;
    }

    .card {
        border-radius: 1rem;
        overflow: hidden;
    }

    .input-group-text {
        border-right: none;
    }

    .form-select, .form-control {
        border-left: none;
    }

        .form-control:focus, .form-select:focus {
            box-shadow: none;
            border-color: #dee2e6;
        }

    .btn-primary {
        background: linear-gradient(45deg, #0d6efd, #0b5ed7);
        border: none;
    }
</style>